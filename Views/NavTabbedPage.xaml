<?xml version="1.0" encoding="utf-8"?>

<TabbedPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TrackTop"
             x:Class="TrackTop.NavTabbedPage"
             BarBackgroundColor="{AppThemeBinding Light=WhiteSmoke, Dark = DimGrey}"
             BarTextColor="{AppThemeBinding Light=Black, Dark = White}"
             SelectedTabColor="{AppThemeBinding Light=MediumPurple, Dark = MediumPurple}"
             UnselectedTabColor="Black"
             xmlns:android="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.AndroidSpecific;assembly=Microsoft.Maui.Controls"
             android:TabbedPage.ToolbarPlacement="Bottom">
    <local:MainPage
        Title="Главная"
        IconImageSource="home_image.png"/>
    <local:FoldersPage
        Title="Папки"
        IconImageSource="folder_image.png"/>
    <local:SettingsPage
        Title="Настройки"
        IconImageSource="settings_image.png"/>
</TabbedPage>